# ============================================
# RUPESH STORE - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env with real keys to git!
# ============================================

# RAZORPAY (Required for payments)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
VITE_RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX

# STORE INFO
VITE_STORE_NAME=Rupesh Store
VITE_STORE_EMAIL=your-email@gmail.com
VITE_STORE_PHONE=9876543210
VITE_STORE_ADDRESS=Your Store Address

# ADMIN
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=your-secure-password

# FIREBASE (Optional)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# CLOUDINARY (Optional)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# GOOGLE ANALYTICS (Optional)
VITE_GA_TRACKING_ID=
